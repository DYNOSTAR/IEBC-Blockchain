generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String         @id @default(uuid())
  email      String         @unique
  password   String
  role       Role           @default(VOTER)
  firstName  String?
  lastName   String?
  nationalId String?        @unique
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  activities UserActivity[]
}

enum Role {
  SUPER_ADMIN
  IEBC_OFFICIAL
  PARTY_AGENT
  OBSERVER
  VOTER
}

model Election {
  id           String         @id @default(uuid())
  name         String
  description  String?
  electionType ElectionType
  startDate    DateTime
  endDate      DateTime
  status       ElectionStatus @default(UPCOMING)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  positions    Position[]
  voters       VoterElection[]
  candidates   Candidate[]
  votes        Vote[]
}

enum ElectionType {
  GENERAL
  BY_ELECTION
}

enum ElectionStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

model Position {
  id         String        @id @default(uuid())
  name       String
  level      PositionLevel
  electionId String
  election   Election      @relation(fields: [electionId], references: [id])
  candidates Candidate[]
  votes      Vote[]
}

enum PositionLevel {
  PRESIDENT
  GOVERNOR
  SENATOR
  MP
  WOMEN_REP
  MCA
}

model Candidate {
  id         String   @id @default(uuid())
  name       String
  party      String
  partyColor String?
  photoUrl   String?
  positionId String
  position   Position @relation(fields: [positionId], references: [id])
  electionId String
  election   Election @relation(fields: [electionId], references: [id])
  votes      Vote[]

  @@unique([positionId, electionId, name])
}

model Voter {
  id             String          @id @default(uuid())
  nationalId     String          @unique
  firstName      String
  lastName       String
  dateOfBirth    DateTime
  county         String
  constituency   String
  ward           String
  pollingStation String
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  elections      VoterElection[]
  votes          Vote[]
}

model VoterElection {
  id         String    @id @default(uuid())
  voterId    String
  electionId String
  hasVoted   Boolean   @default(false)
  voteHash   String?
  votedAt    DateTime?
  voter      Voter     @relation(fields: [voterId], references: [id])
  election   Election  @relation(fields: [electionId], references: [id])

  @@unique([voterId, electionId])
}

model Vote {
  id            String    @id @default(uuid())
  voterId       String
  electionId    String
  positionId    String
  candidateId   String
  encryptedVote String
  voteHash      String
  createdAt     DateTime  @default(now())
  voter         Voter     @relation(fields: [voterId], references: [id])
  election      Election  @relation(fields: [electionId], references: [id])
  position      Position  @relation(fields: [positionId], references: [id])
  candidate     Candidate @relation(fields: [candidateId], references: [id])

  @@unique([voterId, electionId, positionId])
}

model UserActivity {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  details   Json?
  ipAddress String?
  timestamp DateTime @default(now())
}

model County {
  id             String         @id @default(uuid())
  name           String         @unique
  code           Int            @unique
  constituencies Constituency[]
}

model Constituency {
  id       String @id @default(uuid())
  name     String
  countyId String
  county   County @relation(fields: [countyId], references: [id])
  wards    Ward[]
}

model Ward {
  id             String       @id @default(uuid())
  name           String
  constituencyId String
  constituency   Constituency @relation(fields: [constituencyId], references: [id])
}
